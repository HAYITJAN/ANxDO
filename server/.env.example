# --- API server (.env ni nusxalang: copy .env.example .env) -----------------
# Loyiha ildizidan emas, aynan server/ papkasida .env bo‘lishi kerak.
# Render / VPS: Environment Variables ga shu nomlar bilan qo‘shing (qiymatlar maxfiy).

# Platforma odatda PORT ni o‘zi beradi (Render, Railway). Lokal: 5000 yoki istalgan.
# PORT=5000

# Node: production bo‘lsa JWT va CORS qat’iy tekshiriladi (Render odatda NODE_ENV=production).
# NODE_ENV=development

# MongoDB: to‘liq URI yoki parolni alohida (YOUR_PASSWORD_HERE + MONGODB_PASSWORD)
# Atlasda maxsus belgilar bo‘lsa tayyor "connection string" ni nusxalang.
MONGODB_URI=mongodb://127.0.0.1:27017/streamflix
# MONGODB_PASSWORD=faqat_uri_ichida_YOUR_PASSWORD_HERE_bo‘lsa

# Kamida 24 belgi; productionda qisqa bo‘lsa server ishga tushmaydi.
JWT_SECRET=change_this_to_a_long_random_secret_at_least_24_chars

# Frontend (Next) ochilgan domen — CORS. Lokal: 3000. Deploy: https://sizning-frontend.onrender.com
CLIENT_URL=http://localhost:3000

# Admin panel (Vite) domeni — CORS. Deploy: https://sizning-admin.onrender.com
ADMIN_CLIENT_URL=http://localhost:5173

# Qo‘shimcha originlar (vergul bilan): www, preview, boshqa domen
# CORS_EXTRA_ORIGINS=https://www.example.com,https://preview.onrender.com

# Admin kirish (seed / default admin)
ADMIN_EMAIL=admin@streamflix.com
ADMIN_PASSWORD=change_me_in_production

# Kamdan-kam: faqat lokalda 127.0.0.1 da eshitish kerak bo‘lsa
# LISTEN_HOST=127.0.0.1
